# ==============================================
# Penpot MCP Docker Environment Configuration
# ==============================================

# Address the MCP HTTP server binds to inside the container.
PENPOT_MCP_SERVER_LISTEN_ADDRESS=0.0.0.0

# Address the plugin manifest server binds to inside the container.
PENPOT_MCP_PLUGIN_SERVER_LISTEN_ADDRESS=0.0.0.0

# Hostname clients and the plugin should use to reach the MCP server.
PENPOT_MCP_SERVER_ADDRESS=localhost

# Upstream service ports.
PENPOT_MCP_SERVER_PORT=4401
PENPOT_MCP_WEBSOCKET_PORT=4402
PENPOT_MCP_REPL_PORT=4403

# Enable remote mode for non-local deployments.
PENPOT_MCP_REMOTE_MODE=false

# Logging configuration.
PENPOT_MCP_LOG_LEVEL=info
# PENPOT_MCP_LOG_DIR=logs
